@{
}

@model List<DoList.Common.Dtos.UserDto>

@{
    ViewBag.Title = "All Users";
}

<h2>All Users</h2>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>User Name</th>
            <th>Role</th>
            <th>Update</th>
            <th>Delete</th>
            <th><a class="btn btn-outline-primary" href="@Url.Action("Register", "User")">Add</a></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.Firstname</td>
                <td>@user.Lastname</td>
                <td>@user.Username</td>
                <td>@user.Role</td>
                <td><a class="btn btn-secondary" href="@Url.Action("UpdateView", "User", new {userId = user.Id })">Update</a></td>
                <td><a class="btn btn-danger" href="@Url.Action("DeleteUser", "User", new{userId = user.Id})">Delete</a></td>
            </tr>
        }
    </tbody>
</table>
