@{
}


@model DoList.Common.Models.Task.AddTaskModel

@{
    ViewBag.Title = "New Task";
}

@{
    var errorMessage = TempData["ErrorMessage"] as string;
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}
<h2>New Task</h2>

<form method="post" asp-action="AddTask">
    <div class="form-group">
        <label asp-for="Taskname" class="control-label"></label>
        <input asp-for="Taskname" class="form-control" />
        <span asp-validation-for="Taskname" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description" class="control-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="TaskType" class="control-label"></label>
        <input asp-for="TaskType" class="form-control" />
        <span asp-validation-for="TaskType" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="DueDate" class="control-label"></label>
        <input asp-for="DueDate" type="date" class="form-control" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="DueTime" class="control-label"></label>
        <input asp-for="DueTime" type="time" class="form-control" />
        <span asp-validation-for="DueTime" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create Task</button>
</form>
